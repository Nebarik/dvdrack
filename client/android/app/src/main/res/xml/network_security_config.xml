<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- For development: allow all cleartext (HTTP) traffic -->
    <!-- This enables connection to local servers on any IP address -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
